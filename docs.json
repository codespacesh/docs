{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Codewire",
  "colors": {
    "primary": "#0EA5E9",
    "light": "#0EA5E9",
    "dark": "#0EA5E9"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 510
    },
    "body": {
      "family": "Inter",
      "weight": 450
    }
  },
  "background": {
    "color": {
      "dark": "#08090a"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://codewire.sh/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/create-account",
              "getting-started/sign-in",
              "getting-started/create-organization",
              "getting-started/create-your-first-resource",
              "getting-started/navigate-the-dashboard",
              "getting-started/launch-workspace"
            ]
          },
          {
            "group": "Organizations",
            "pages": [
              "organizations/overview",
              "organizations/manage-members",
              "organizations/invite-members",
              "organizations/accept-invitation",
              "organizations/billing",
              "organizations/secrets"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/overview",
              "resources/create-resource",
              "resources/resource-dashboard",
              "resources/upgrade-coder-version",
              "resources/retry-failed-provision",
              "resources/force-reprovision",
              "resources/delete-resource",
              "resources/custom-domains",
              "resources/codewire-relay"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "workspaces/overview",
              "workspaces/manage-workspaces",
              "workspaces/build-logs"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/github-integration",
              "settings/custom-login-provider",
              "settings/security"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/resource-statuses",
              "reference/provisioning-events",
              "reference/subscription-plans",
              "reference/faq"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/platform",
              "cli/sessions",
              "cli/orchestration",
              "cli/messaging",
              "cli/relay",
              "cli/kv",
              "cli/mcp",
              "cli/configuration",
              "cli/coder-module"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://codewire.sh/dashboard",
          "icon": "browser"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/codewiresh"
    }
  }
}
