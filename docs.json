{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Codespace",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://codespace.sh/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/create-account",
              "getting-started/sign-in",
              "getting-started/create-your-first-instance",
              "getting-started/navigate-the-dashboard"
            ]
          },
          {
            "group": "Instances",
            "pages": [
              "instances/overview",
              "instances/create-instance",
              "instances/instance-dashboard",
              "instances/upgrade-coder-version",
              "instances/retry-failed-provision",
              "instances/delete-instance",
              "instances/custom-domains"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "workspaces/overview",
              "workspaces/manage-workspaces",
              "workspaces/build-logs"
            ]
          },
          {
            "group": "Team",
            "pages": [
              "team/overview",
              "team/invite-members",
              "team/accept-invitation",
              "team/manage-members"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/github-integration",
              "settings/custom-login-provider",
              "settings/subscription-and-usage",
              "settings/security"
            ]
          },
          {
            "group": "Apps",
            "pages": [
              "apps/desktop-app",
              "apps/mobile-app"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/instance-statuses",
              "reference/provisioning-events",
              "reference/subscription-plans",
              "reference/faq"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://codespace.sh/dashboard",
          "icon": "browser"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/codespacesh"
    }
  }
}
